    // 清理audioMap中所有Howl实例
    function cleanupAudioMap() {
        for (let key in audioMap) {
            if (audioMap.hasOwnProperty(key)) {
                let howlInstance = audioMap[key];
                if (howlInstance && typeof howlInstance.unload === 'function') {
                    howlInstance.unload();  // 释放单个音频资源
                }
                delete audioMap[key];  // 从audioMap中移除引用
            }
        }
    }

    // 封装Howl加载为Promise
    function loadSound(key,url) {
        return new Promise((resolve) => {
            var sound = new Howl({
                src: [url],
                html5: isSafari,
                onload: () => {
                    audioMap[key] = sound;
                    //console.log(`音频 ${url} 加载完成`);
                    resolve(sound);
                },
                onloaderror: (error) => {
                   // console.error(`音频 ${url} 加载失败: `, error);
                    resolve(null); // 即使加载失败也resolve，保证流程继续
                },onend: function() {
                    if(!isxunhuanbf)
                    {
                         $(".dcxqdbf").removeClass('audioClick');
                    }
                   }
            });
        });
    }

