          // 给所有动画元素添加统一class，方便选择
        const svgAnimations = document.querySelectorAll('.svg-animation');
        // 存储动画原本的repeatCount值
        const originalRepeatCounts = new Map();

        // 暂停动画：移除循环属性，让动画停止在当前状态
        function pauseAnimations() {
          svgAnimations.forEach(animation => {
            // 保存原始的repeatCount值
            const original = animation.getAttribute('repeatCount');
            originalRepeatCounts.set(animation, original);
            // 移除循环，动画执行完当前周期后停止
            animation.setAttribute('repeatCount', '0');
            // 对于已经在运行的动画，强制刷新状态
            animation.endElement();
          });
        }

        // 恢复动画：恢复循环属性，重新启动动画
        function resumeAnimations() {
          svgAnimations.forEach(animation => {
            // 恢复原始的repeatCount值
            const original = originalRepeatCounts.get(animation) || 'indefinite';
            animation.setAttribute('repeatCount', original);
            // 重新启动动画
            animation.beginElement();
          });
        }

        // 监听页面可见性变化
        document.addEventListener('visibilitychange', () => {
          if (document.hidden) {
            pauseAnimations();
            //console.log("关闭动画");
          } else {
            resumeAnimations();
            //console.log("开启动画");
          }
        });



