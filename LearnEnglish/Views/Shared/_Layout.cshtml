        var audioElement = null;

      function changeAudioSource(myAudio,newSrc) {

          if(audioElement!=null){
              audioElement.pause();
              audioElement.currentTime = 0; // 将播放位置重置到开始处
          }

         audioElement = document.getElementById(myAudio);

        // 假设我们只有一个<source>元素，或者我们想要替换所有的<source>元素
        let sourceElement = audioElement.querySelector('source');
        if (!sourceElement) {
            // 如果没有<source>元素，则创建一个
            sourceElement = document.createElement('source');
            audioElement.appendChild(sourceElement);
        }

        // 设置新的src属性

             sourceElement.src = newSrc; // 替换为新的音频文件URL
              // 调用load()方法来重新加载音频
            audioElement.load();


              // 监听 ended 事件，播放完毕执行
             audioElement.addEventListener('ended', function() {

              if(isxunhuanbf){
                  audioElement.play();
              }
              else{
                   $(".dcxqdbf").removeClass('audioClick');
              }
            });

        // 监听加载完成事件（可选）
        audioElement.addEventListener('canplay', function() {
           // console.log('音频现在可以播放');
            // 在这里可以添加自动播放或其他逻辑
            audioElement.play();
        }, { once: true }); // 使用{ once: true }来确保事件监听器只执行一次
    }



