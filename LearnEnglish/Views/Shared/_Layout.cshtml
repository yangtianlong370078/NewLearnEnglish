         function playAudio(key,retryCount = 0) {

             //清空当前
             if(dqaudio!=null)
             {
                 dqaudio.unload();
                 dqaudio=null;
                // alert("清空了之前的");
             }

               var audio = audioMap[key];
               if (audio) {
                   if(isbfaudio==1){
                     //  alert("播放了预设");
                       isbfaudio=0;
                       audYS.play();
                   }
                   dqaudio =audio;


                  dqaudio.load();
                  dqaudio.loop(isxunhuanbf);

                   // 确保sound已经加载完成
                  if (dqaudio.state() === 'loaded') {
                    // 取消静音并播放
                    dqaudio.mute(false);
                    dqaudio.play();
                  } else {
                    // 如果还没加载完成，可以在onload回调中处理
                    dqaudio.once('load', function() {

                      dqaudio.mute(false);
                      dqaudio.play();
                    });
                  }


                   //监听播放情况
                   dqaudio.once('playerror', function() {
                      alert('播放失败，尝试重试...');
                      isbfaudio=1;
                      if (retryCount < 3) {
                          // 如果重试次数小于3，则重新加载音频并递归调用此函数
                          dqaudio.once('load', function() {
                              console.log('音频重新加载成功');
                          });
                          dqaudio.load(); // 重新加载音频

                          // 递归调用自身，增加重试计数
                          playAudio(key, retryCount + 1);
                      } else {
                          alert('播放失败，已达最大重试次数');
                          console.error('播放失败，已达最大重试次数');
                      }
                   });


               } else {
                // playAudioV2("");
               }





         }

