              //修改为在document级别监听，以便更灵活地控制事件冒泡
    $(document).on('click', '.kctitle', function (event) {


        var target = event.target;
        if ($(target).hasClass('box-btn-slide')) {
            // 如果直接点击的是.box-btn-slide，则不执行阻止冒泡，因为这是期望的行为
            return;
        }

        // 执行点击操作，这里尝试模拟点击，但需谨慎处理循环调用问题
        var slideBtn = $(this).find(".box-btn-slide");
        var simulatedEvent = new MouseEvent('click', {
            bubbles: true, // 控制事件是否冒泡，默认为true
            cancelable: true,
            view: window
        });

        // 触发模拟的点击事件
        if(slideBtn.length>0)
        {
            slideBtn[0].dispatchEvent(simulatedEvent);
        }

    });

