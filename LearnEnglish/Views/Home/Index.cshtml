<script>
    //显示功能区
    $(".gnqan").show();

     


    window.addEventListener('resize', updateAvailableHeight);
    function updateAvailableHeight() { 
        
          var windowHeight = window.innerHeight || document.documentElement.clientHeight || document.body.clientHeight;
       if(!isMobile)
        {
            $('.aaazzz').slimScroll({
            height: windowHeight
         });
        }
   }  


   $(document).ready(function() {

        updateAvailableHeight(); 

        var wxid =  parseInt($(".wxid").val());

        var wxpagename = $(".wxpagename").val();
      //  alert("wxid="+wxid+"wxpagename="+wxpagename);
       if(wxpagename!=""){
          // tbtab(0);
           showpage("main");
            if(wxpagename=="learnEnglishTable"){
               
                requestUrlHtml('/Course/learnEnglishTable?kc='+wxid, "","main");
            }
            else  if(wxpagename=="ExamContentTable"){
               requestUrlHtml('/Exam/ExamContentTable?id='+wxid, "","main");
            }
            else  if(wxpagename=="HearingLX"){
               requestUrlHtml('/Hearing/HearingLX?kc='+wxid, "","main");
            } 
       }else{

         var url = window.location.href; 
         var url2 = window.location.origin+"/";
         if(url==url2){
              tbtab(1);
              Home($(".homebtn"),isMobile?1:0);
         }
         else if(isMobile){
               tbtab(1);
               Home($(".homebtn"),isMobile?1:0);
         }
       }

       //账户信息
        requestData("/Home/GetUiserInfo","").then((data) => {
                    if (data.success) {
                       let day = data.day;
                       let hour = data.hour;
                       let minute = data.minute;

                      let text="";

                      if (day <= 7)
                       {
                           $(".gqys").removeClass("text-info").removeClass("fa-users").addClass("text-danger").addClass("fa-warning");
                           $(".gqtb").addClass("text-danger");

                       }
                       else{
                           $(".gqys").removeClass("text-danger").removeClass("fa-warning").addClass("text-info").addClass("fa-users");
                           $(".gqtb").removeClass("text-danger");
                       }


                         if (day > 0)
                           {
                                    text="还剩" +day+"天";                                                            
                           }
                           else if (hour > 0)
                           {
                                   text="还剩" +hour+"小时";                                                                 
                           }
                           else if (minute > 0)
                           {
                                    text="还剩" +minute+"分钟";                                                                         
                           }
                           else
                           {
                                     text="(以过期)";                                                                       
                           }
                            $(".gqsj").text(text);
                    }
                    else {
                        czjieguo(data.msg, 1);
                    }

            }).catch((error) => {
               czjieguo(error.msg, 1);
            });




      });


     function ModifyPassword(UserID) {

        $("#originalPwd").val("");
        $("#newPwd1").val("");
        $("#newPwd2").val("");
    }

     function SavePwd() {

        var oldPwd = $("#originalPwd").val();
        var newPwd1 = $("#newPwd1").val();
        var newPwd2 = $("#newPwd2").val();

        if ($.trim(oldPwd) == "") {
            layer.tips('原始密码不能为空！', '#originalPwd');
            return false;
        }

        if ($.trim(newPwd1) == "") {
            layer.tips('新密码不能为空！', '#newPwd1');
            return false;
        }

        if ($.trim(newPwd2) == "") {
            layer.tips('新密码不能为空！', '#newPwd2');
            return false;
        }

        if (newPwd1 != newPwd2) {
            layer.tips('两次密码输入不一致！', '#newPwd2');
            return false;
        }



          requestData("/Login/ModifyPassword",{OldPwd: oldPwd, NewPwd: newPwd2}).then((data) => {
                     if (data.success) {
                         $('.gbck').click();
                         czjieguo("修改成功，请使用新密码重新登录。", 0);

                         setTimeout(function() {  
                             var baseUrl = window.location.protocol + "//" + window.location.host + "/Login/Login";
                             window.location.href = baseUrl;
                          }, 2000); // 2000毫秒 = 2秒

                      }
                     else {
                         czjieguo(data.msg, 1);
                     }

            }).catch((error) => {
               czjieguo(error.msg, 1);
            });


    }

 function   LoginOut(){
              swal({
            title: "确定退出当前登录账号？",
            type: "warning",
            showCancelButton: true,
            cancelButtonText: "取消",
            confirmButtonColor: "#DD6B55",
            confirmButtonText: "退出",
            closeOnConfirm: false
        }, function () {

             var baseUrl = window.location.protocol + "//" + window.location.host+"/Login/Login";   
            window.location.href = baseUrl; 

        });

 }

    function qkdc(){
        $(".cxdc").val("");
         $('.qxan').addClass('hide');
    }
   function addtodcb() {
         var en = $(".cxdc").val().trim().toLowerCase();
          let courseId = localStorage.getItem('courseId');

        var layerIndexv = layer.open({
            type: 1, //page层
            area: ['300px', '70px'],
            title: '',
            shade: 0.1, //遮罩透明度
            moveType: 0, //拖拽风格，0是默认，1是传统拖动
            shift: -1, //0-6的动画形式，-1不开启
            closeBtn: 0,
            content: '<div id="xinglailoading" style="text-align: center; line-height:70px;"><img title="操作中" alt="操作中" src="../Content/img/sunjing_loading2.gif" />&nbsp;&nbsp;操作中，请稍等... ...</div>'
        });
        $('.btn-close').click();


          requestData("/Course/SaveCoursecontent",{ courseId: courseId, en: en, cn: '' }).then((data) => {
                    layer.close(layerIndexv);
                    if (data.success) {
                        czjieguo("操作成功！", 0);
                       $(".cxdc").val("");
                        suaxinMyCategoryList(1);
                    }
                    else {
                        czjieguo(data.msg, 1);
                    }

                }).catch((error) => {
                   czjieguo(error.msg, 1);
            });


    }
    

   async  function bfdctwo(language,word,value,dom){
        var ind=  $(dom).children(".xhbtn").index(".xhbtn");
        $(".xhbtn:eq("+(ind==0?1:0)+")").removeClass("xunhuanbofank").addClass("xunhuanbofang");
       
        let isxh = $(dom).children(".xhbtn").hasClass('xunhuanbofank');


       isxunhuanbf = isxh;
       let dqisbf = $(dom).children(".pronounce").hasClass('audioClick');
        $(".dcxqdbf").removeClass('audioClick');
       if(dqisbf&&!isxh){
          bgaduitbf();
          return false;
       }
       
       

       $(dom).children(".pronounce").addClass('audioClick');
       
      
      
         //暂时注释，避免没有音频，取查询的都用audio播放
         let isenaudio =  $("#gg_isenaudio").val();
         let isusaudio =  $("#gg_isusaudio").val();
         let dqisaudio = language=="Speech_EN"?isenaudio:isusaudio;
         var key = language+word;
         var audio = audioMap[key];  

         //手机端查询的时候，用h5方式播放
         let ish5paly = isMobile&&$("#iscx").val()==1;
      
        if (!audio  && !ish5paly) {  
            
            // setAudioMap(key,value);
            if(dqisaudio==1)
            {
               
                 await loadSound(key,value);
            }
           
          }
         

          if(dqisaudio==1 && !ish5paly){
            
               playAudio(key);
          }else{
              let type = language=="Speech_EN"?1:0;
              let newSrc = 'http://dict.youdao.com/dictvoice?type='+type+'&audio='+word;
               changeAudioSource('GG_'+language,newSrc)
          }

    }


    function dccx(dom){

        var dc = $(".cxdc").val().trim().toLowerCase();
        if(dc==""){

           return false;
      }
      else{

           $("#adddcb").hide();
        
        //单词查询
        lexiconDeatil(dc,true)

      }
    }



    function WordExist(){

        var en = $(".cxdc").val().trim().toLowerCase();

          let kc = localStorage.getItem('courseId');


            requestData("/Word/WordExist",{  kc: kc, en: en }).then((data) => {
                    $("#gg_isenaudio").val(data.isenaudio);
                $("#gg_isusaudio").val(data.isusaudio);
                if (data.data) {
                    $("#adddcb").show();
                    
                }
                else {
                   $("#adddcb").hide();
                   
                }

            }).catch((error) => {
               czjieguo(error.msg, 1);
            });

    }

    function lexiconDeatil(dc,iscx){

       
             $("#querydcdetailshow").html("");
             $("#dcdetailshow").html("");
       


          requestUrlHtml("/Word/lexiconDeatil", {
            word: dc,
            iscx:iscx
