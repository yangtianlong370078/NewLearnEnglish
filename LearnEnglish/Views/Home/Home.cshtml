                     b: taxkcount
                 });
        }


        initChart(year);

     }


         // 初始化图表函数
     function initChart(dy) {


         // 计算初始颜色
        // calculateColors();

         if(barChart==null){
         // 创建图表
         barChart = Morris.Bar({
             element: 'bar-chart',
           //  data: chartData,
             xkey: 'y',
             ykeys: ['a', 'b'],
             labels: ['A', 'B'],
             barColors: ['#00baff', '#04a08b'],
             hideHover: 'auto',
             gridLineColor: '#eef0f2',
              barSizeRatio: 0.4, // 减小柱子宽度比例
              barGap: 1,         // 增加柱子间距
             resize: true,
             parseTime: false,
             gridTextFamily: "'Microsoft YaHei', sans-serif",
           //   xLabelAngle: 360,
                 
         });

          if(chartData.length>0){
                      updateChartData(chartData,dy);
                }

          }
          else{
               if(chartData.length>0){
                     updateChartData(chartData,dy);
               }

          }
     }

    function customHover(index, options, content, row) {



        let jg = "";
        let xx = "";
        let rw = "";
        let wc="";
        let a =  row.isyeartask?row.a-1:row.a;
        let b =  row.isyeartask?row.b-1:row.b;
        if(row.status==1){
             if(row.b-1>0){
               jg = "未开始";
                rw = `<div>任务单词: ${b}</div>`;
             }
             else{
                 jg = "无任务";
             }
        }
        else{
            if(row.b-1>0){
                if(row.jg<100){
                    jg = "未完成";
                }else{
                    jg = "已完成";
                }
                  xx = `<div>新学单词: ${a}</div> `;
                  rw = `<div>任务单词: ${b}</div>`;
                  wc=`<div class="jg-value">完成情况: ${row.jg}%</div>`;
             }
             else{
                 jg = "无任务";
                 xx = `<div>新学单词: ${a}</div> `;
             }
        }


         return `<div class="custom-tooltip">
             <div class="tooltip-title">${row.y} (${jg})</div>
             ${xx}
             ${rw}
             ${wc}
         </div>`;
     }

         // 计算每个数据点的颜色
     function calculateColors(yy) {
         let date=new Date();
          let dy =  date.getFullYear();
          let dm = date.getMonth();
          dm+=1;

          const totalA = chartData.reduce((sum, item) => sum + item.a, 0);
          const totalB = chartData.reduce((sum, item) => sum + item.b, 0);
         chartData.forEach(item => {
             const jg = item.b === 0 ? 0 : Math.round(item.a / item.b * 100);
             item.jg = jg;
             item.yy=yy;
             let mm = parseInt(item.y,10);
             item.status = yy>dy||(yy==dy&&mm>dm)?1:0;
             item.isyeartask = totalA>0||totalB>0;

             if(yy>dy||(yy==dy&&mm>dm)||item.b === 0)
             {
                  item.textColor = 'grey';
             }
             else{
                  if (jg === 0) {
                 item.textColor = '#ff562f'; // 红色
             } else if (jg < 100) {
                 item.textColor = '#ff9920'; // 黄色
             } else {
                 item.textColor = '#04a08b'; // 绿色
             }
             }

             //用于显示，避免显示0啥也不显示，在鼠标悬浮窗的时候-1
             if(totalA>0||totalB>0)
             {
                 item.a=item.a+1;
                 item.b=item.b+1;
             }
         });
     }
         // 应用文本颜色到图表
     function applyTextColors() {
         setTimeout(() => {

             const svg = document.querySelector('#bar-chart svg');
             if (!svg) return;

             // const monthLabels = svg.querySelectorAll('.morris-categories-axis text tspan');
             // monthLabels.forEach((label, index) => {
             //     const dataItem = chartData[index];
             //     if (dataItem) {
             //         label.style.fill = dataItem.textColor;
             //         label.style.fontWeight = 'bold';
             //         label.setAttribute('data-jg', `${dataItem.jg}%`);
             //     }
             // });

              // 方法1：通过文本内容匹配（最可靠）
             const allTexts = svg.querySelectorAll('text');
             allTexts.forEach(text => {
                 const monthText = text.textContent.trim();
                 const dataItem = chartData.find(d => d.y === monthText);

                 if (dataItem) {
                     text.style.fill = dataItem.textColor;
                     if(dataItem.textColor!="grey")
                     {
                          text.style.fontWeight = 'bold';
                     }

                     text.style.fontSize = '12px';
                     text.setAttribute('data-jg', dataItem.jg + '%');
                 }
             });


         }, 500);
     }


         // 更新图表数据
     function updateChartData(newData,isdy) {
         // 1. 更新全局数据
         chartData = newData;

         // 2. 重新计算颜色
         calculateColors(isdy);

         // 3. 更新图表
         if (barChart && barChart.setData) {
             // 使用 setData 方法更新数据
             barChart.setData(chartData);
             // 手动触发颜色更新
             applyTextColors();
         } else {
             // 如果 setData 不可用，重建图表
             $('#bar-chart').empty();
             initChart();
         }

         // 4. 处理窗口缩放
         $(window).trigger('resize');
     }



