                 let taxkcount = 0;//任务数量
                 let datedaytype = 0;//0为当前月；-1为已过去时间；1为还未到时间
                 if (result != undefined) {
                     Count = result.totalcount;
                     let totalcount = result.totalcount;

                     if (result.task != null && result.task != undefined) {
                         taxkcount = result.task.count;
                     }
                     if (taxkcount > 0) {
