     function stringToMonthDate(str, defaultDay = '01') {
         const [year, month] = str.split('-').map(Number);
         return new Date(year, month - 1, defaultDay); // 注意：月份在Date中是0-based的
     }
     function parseCustomDate(dateString,mon) {
         const parts = dateString.match(/(\d{4})年(\d{1,2})月/);
         if (parts) {
             let year = parseInt(parts[1], 10);
             let month = parseInt(parts[2], 10)- 1; ; // 注意月份需要减1
             let day = 1; // 由于只有年和月，我们假设天为1

             month += mon;
             let date = new Date(year, month, day);
             return date;
         } else {
             return null;
         }
     }

