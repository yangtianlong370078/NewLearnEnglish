            async function playAudio88(text, rul, isplay = true) {

                // 尝试从本地缓存中获取音频文件
                const localUrl = await getFromCache(text);
                if (localUrl) {
                    // 如果本地已有缓存，直接使用本地地址播放
                    playFromLocal(localUrl);
                } else {
                    // 如果本地无缓存，从服务器下载并缓存到本地
                    fetchAndCache(rul, text);
                }

                async function getFromCache(key) {
                    return new Promise((resolve, reject) => {
                        const request = indexedDB.open('audio_cache', 1);
                        request.onerror = reject;

                        request.onsuccess = () => {
                            const db = request.result;
                            const tx = db.transaction('audio', 'readonly');
                            const store = tx.objectStore('audio');

                            const getRequest = store.get(key);
                            getRequest.onerror = reject;

                            getRequest.onsuccess = () => {
                                const result = getRequest.result;
                                if (result) {
                                    resolve(result.url);
                                } else {
                                    resolve(null);
                                }
                            };
                        };

                        request.onupgradeneeded = event => {
                            const db = event.target.result;
                            if (!db.objectStoreNames.contains('audio')) {
                                db.createObjectStore('audio', { keyPath: 'key' });
                            }
                        };
                    });
                }

                async function fetchAndCache(rul, key) {
                    try {
                        const response = await fetch(rul);
                        const arrayBuffer = await response.arrayBuffer();
                        const blob = new Blob([arrayBuffer], { type: 'audio/mp3' }); // 假设音频格式为mp3
                        const url = URL.createObjectURL(blob);

                        const db = await openDatabase();
                        const tx = db.transaction('audio', 'readwrite');
                        const store = tx.objectStore('audio');
                        store.put({ key, url });

                        await tx.complete;

                        // 播放缓存的音频
                        playFromLocal(url);

                        // 清理资源
                        // URL.revokeObjectURL(url);
                    } catch (err) {
                        console.error('Error fetching audio file: ', err);
                    }
                }

                async function openDatabase() {
                    return new Promise((resolve, reject) => {
                        const request = indexedDB.open('audio_cache', 1);
                        request.onerror = reject;
                        request.onsuccess = () => resolve(request.result);
                        request.onupgradeneeded = event => {
                            const db = event.target.result;
                            if (!db.objectStoreNames.contains('audio')) {
                                db.createObjectStore('audio', { keyPath: 'key' });
                            }
                        };
                    });
                }

                async function playFromLocal(localUrl) {
                    if (isplay) {
                        //const audioContext = new (window.AudioContext || window.webkitAudioContext)();
                        //const audioBuffer = audioContext.createBufferSource();
                        //audioContext.decodeAudioData(await (await fetch(localUrl)).arrayBuffer(), buffer => {
                        //    audioBuffer.buffer = buffer;
                        //    audioBuffer.connect(audioContext.destination);
                        //    audioBuffer.start(0);
                        //}, err => {
                        //    console.error('Error decoding audio data: ', err);
                        //});




                        await fetch(localUrl)
                            .then(response => response.arrayBuffer())
                            .then(arrayBuffer => {
                                return new Promise((resolve, reject) => {
                                    const audioContext = new (window.AudioContext || window.webkitAudioContext)();
                                    const audioBuffer = audioContext.createBufferSource();
                                    audioContext.decodeAudioData(arrayBuffer, buffer => {
                                        audioBuffer.buffer = buffer;
                                        audioBuffer.connect(audioContext.destination);
                                        audioBuffer.start(0);
                                        resolve();
                                    }, err => {
                                        console.error('Error decoding audio data: ', err);
                                        reject(err);
                                    });
                                });
                            })
                            .catch(err => {
                                console.error('Error fetching audio file: ', err);
                            });
                    }
                }
            }

