@{
    Layout = null;
}

@using LearnEnglish.Models.Dtos
<!-- Style-->
@model PagedList<LearnEnglish.Models.Dtos.ShowTranslateDto>



<div>

    <input type="hidden" value="@ViewData["brs"]" class="xzbrs" />
    <input type="hidden" value="@ViewData["wlj"]" class="xzwlj" />
    <input type="hidden" value="@ViewData["yzw"]" class="xzyzw" />


    @if (Model != null && Model.Count > 0)
    {
        @* <div class="dv" style=" display: flex;flex-wrap: wrap;margin:10px;justify-content: center;">*@
        <div class="row wbpd">
            @{
                var tp = Convert.ToInt32(ViewData["tp"]);
            }
            @foreach (ShowTranslateDto item in Model)
            {


                <div class="col-6 col-md-4 col-xl-2  wyg nbpd">

                    <div class="  border-gainsboro text-center  nr nrsty example p-10 nr_lexiconid_@item.lexiconId" style="cursor: pointer;--yy:16px;"
