                         data-en="@item.en"
                         data-cn="@item.cn"
                         data-zt="@item.zt"
                         data-coursecontentid="@item.coursecontentId"
                         data-lexiconid="@item.lexiconId"
                         data-isupdate="@item.isUpdate"
                         data-iscollect="@item.iscollect"
                         data-zyno="@item.zynumber"
                         data-yzno="@item.yznumber"
                         data-txno="@item.txnumber"
                         data-fyno="@item.fynumber"
                         data-id="@item.id">
                        <div style="display:flex;justify-content: space-between;position:relative;z-index:1;" data-bs-toggle="@string.Format("{0}", tp == 4 ? "" : "modal")" data-bs-target="#dcdetail" onclick="bfdc(this)">
                            <div>
                                <div class="box-body  bbsr-0 bber-0 sp" style="padding:6px;display:flex;justify-content: space-between;">
                                    <span style="text-align: left; line-height: 1.7rem;font-weight:bold" class="wb @string.Format("{0}",tp==2||tp==3||tp==10?"fs-18":"fs-16") @string.Format("{0}",tp==4?"hide":"")">@item.name</span>
                                    @*  <span style="height: 1.7rem" class="fa fa-fw fa-circle-o djs @string.Format("{0}",tp==4?"":"hide")"></span> *@
                                    @* <i style="height: 1.7rem" class="mdi mdi-stop-circle-outline  djs @string.Format("{0}",tp==4?"":"hide")"></i> *@
                                    <span style="height: 1.7rem" class="glyphicon glyphicon-ok ok hide"></span>
