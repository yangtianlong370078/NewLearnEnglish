                                </div>

                                <p style="text-align: left; padding:0px 6px 5px 6px;overflow: hidden;text-overflow: ellipsis;white-space: nowrap;" class="mb-0 text-fade @string.Format("{0}",tp==1?"fs-18":"fs-16")  spy sq  @string.Format("{0}",tp==10&&tp!=4?"":"hide")">@string.Format("{0}", item.value == "" ? "-" : item.value)</p>
                            </div>
                            <div style="display: flex;flex-direction: column;">

                                @{
                                    var zybrightness = "fa-circle-o";
                                    if (item.zynumber >= 10)
                                    {
                                        zybrightness = "fa-circle";
                                    }
                                    else if (item.zynumber >= 5 && item.zynumber < 10)
                                    {
                                        zybrightness = "fa-adjust";
                                    }

                                    var yzbrightness = "fa-circle-o";
                                    if (item.yznumber >= 10)
                                    {
                                        yzbrightness = "fa-circle";
                                    }
                                    else if (item.yznumber >= 5 && item.yznumber < 10)
                                    {
                                        yzbrightness = "fa-adjust";
                                    }

                                    var txbrightness = "fa-circle-o";
                                    if (item.txnumber >= 10)
                                    {
                                        txbrightness = "fa-circle";
                                    }
                                    else if (item.txnumber >= 5 && item.txnumber < 10)
                                    {
                                        txbrightness = "fa-adjust";
                                    }

                                    var fybrightness = "fa-circle-o";
                                    if (item.fynumber >= 10)
                                    {
                                        fybrightness = "fa-circle";
                                    }
                                    else if (item.fynumber >= 5 && item.fynumber < 10)
                                    {
                                        fybrightness = "fa-adjust";
                                    }
                                }

                                <i class="fa @zybrightness zydf @string.Format("{0}",tp==1||tp==10?"":"hide") text-primary" style="line-height: 16px;width:16px;"></i>
                                <i class="fa @yzbrightness yzdf @string.Format("{0}",tp==2||tp==10?"":"hide") text-success" style="line-height: 16px;width:16px;"></i>
                                <i class="fa @txbrightness txdf @string.Format("{0}",tp==4||tp==10?"":"hide") text-info" style="line-height: 16px;width:16px;"></i>
                                <i class="fa @fybrightness fydf @string.Format("{0}",tp==3||tp==10?"":"hide") text-warning" style="line-height: 16px;width:16px;"></i>
                            </div>
                        </div>

                        <input class="@string.Format("{0}",(tp==1||tp==2||tp==4)? "":"hide") form-control mt-5 fs-16 sq inputbdcolor " @string.Format("{0}", tp == 4 ? "disabled" : "") data-value="@item.value" data-id="@item.id" data-lexiconid="@item.lexiconId" data-en="@item.en" style="position:relative;flex-basis: 0;z-index:1; flex-grow: 1;line-height: 1.5;font-size: 1.16rem;" type="text" />

                        <div style="justify-content: center;align-items: center;display:flex;position:relative;z-index:1;" class="mb-0 fylx @string.Format("{0}",tp==3?"":"hide")">
                            <span class="fybtnys icon-Mic fs-24 m-5 p-10 mkf_@item.en" onclick="fykaiguan(this,'@item.en')" style="cursor: pointer;height:44px;width:44px;">
                                <span class="path1"></span><span class="path2"></span>
                            </span>
                            <div class="hide m-5 lyzbtn_@item.en" onclick="shibiefy(this,'@item.en')" style="cursor: pointer;height:44px;align-items: center;display:flex;">
                                <div class="sound-waves">
                                    <div class="wave"></div>
                                    <div class="wave"></div>
                                    <div class="wave"></div>
                                    <div class="wave"></div>
                                    <div class="wave"></div>
                                </div>
                            </div>
                            <span class="hide m-5 shibieing_@item.en" onclick="quxiaocaxun(this,'@item.en')" style="display: flex;height: 44px;align-items: center;"><i class="fa fs-18 fa-spin fa-refresh " style="margin:0px 5px 0px 10px;font-size: 17px;"></i></span>
                        </div>

                    </div>
                </div>

            }

        </div>


    }
    else
    {

        <div class="text-left   my-20 p-20 nrsty  example">
            <span style="position: relative;z-index: 1;">没有了~</span>
        </div>
    }


</div>

