{
  "lexiconMongoDBOptions": {
    "lexiconCollectionName": "lexicondetail",
    "ConnectionString": "mongodb://localhost:27017",
    "DatabaseName": "lexicondetaildb"
  },
  "ConnectionStrings": {
    "lexiconMysqlDb": "server=localhost;user id=<DB_USER>;password=<DB_PASSWORD>;persistsecurityinfo=True;database=learnenglish;charset=utf8mb4;port=3306"
  },
  "Redis": {
    "Default": {
      "Connection": "localhost:6379",
      "InstanceName": "learnenglish",
      "DefaultDb": 1
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Jwt": {
    "Key": "<JWT_SECRET_KEY_至少32位随机字符串>",
    "Issuer": "LearnEnglish",
    "Audience": "LearnEnglishApi",
    "AccessTokenExpireMinutes": 120,
    "RefreshTokenExpireDays": 7
  },
  "XfyunConfig": {
    "AppId": "<XFYUN_APP_ID>",
    "ApiKey": "<XFYUN_API_KEY>",
    "ApiSecret": "<XFYUN_API_SECRET>",
    "AsrMode": "short-stream"
  },
  "BaiDuConfig": {
    "AppId": "<BAIDU_APP_ID>",
    "ApiKey": "<BAIDU_API_KEY>",
    "ApiSecret": "<BAIDU_API_SECRET>"
  },
  "Whisper": {
    "ModelPath": "<WHISPER_MODEL_PATH>",
    "CmuDictPath": "<CMU_DICT_PATH>"
  }
}
